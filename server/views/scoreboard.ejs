<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Scoreboard</title>
    <style>
      body {
        background: #121212;
        color: white;
        font-family: monospace;
        padding: 2rem;
        text-align: center;
      }
      table {
        margin: auto;
        border-collapse: collapse;
        width: 80%;
      }
      th,
      td {
        border: 1px solid #444;
        padding: 0.5rem 1rem;
      }
      th {
        background: #222;
      }
    </style>
  </head>
  <body>
    <h1>🏆 Scoreboard</h1>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Guesses</th>
          <th>Word Length</th>
          <th>Time</th>
        </tr>
      </thead>
      <tbody>
        <% scores.forEach((s, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= s.name %></td>
          <td><%= s.guesses %></td>
          <td><%= s.wordLength %></td>
          <td><%= s.timeInSeconds %>s</td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </body>
</html>
